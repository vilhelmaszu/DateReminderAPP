# Background push (optional). Without these, the app still works — it just
# shows the in-app reminders and hides the "Background reminders" toggle.
# Get both values by deploying worker/ (see worker/README.md).

VITE_PUSH_API=https://date-reminder-push.your-subdomain.workers.dev
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
